# ──────────────────────────────────────────────────────────────────
# Test Lab — variaveis de ambiente
# ──────────────────────────────────────────────────────────────────
# Copie este arquivo para .env.local e preencha com os valores do
# seu projeto Supabase.
#
# Onde encontrar:
#   1. Acesse https://supabase.com e abra seu projeto.
#   2. Va em Settings -> API.
#   3. "Project URL"      -> VITE_SUPABASE_URL
#   4. "anon public" key  -> VITE_SUPABASE_ANON_KEY
#
# IMPORTANTE: nunca coloque a chave "service_role" aqui — ela so
# pertence ao backend e tem acesso total ao banco.
# ──────────────────────────────────────────────────────────────────

VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-public-key-aqui
